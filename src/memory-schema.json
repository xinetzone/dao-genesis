{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://daoagents.github.io/dao-genesis/schema/memory-record.json",
  "title": "dao-genesis Review Memory Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "timestamp",
    "participants",
    "task_type",
    "decisions",
    "success_factors",
    "failure_reasons",
    "best_practices",
    "action_items",
    "status"
  ],
  "properties": {
    "review_id": {
      "type": "string",
      "pattern": "^REV-[0-9]{8}-[0-9]{3}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "task_type": {
      "type": "string"
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "success_factors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "failure_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "best_practices": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "action_items": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ]
    }
  }
}
